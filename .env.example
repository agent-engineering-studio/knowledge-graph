# ── Neo4j (Graph DB) ────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=yourpassword
NEO4J_DATABASE=neo4j

# ── Redis (Vector Store) ────────────────────────────────────────────
REDIS_URL=redis://redis:6379
REDIS_INDEX_NAME=kg_vectors
REDIS_VECTOR_DIM=768

# ── Ollama (LLM Inference) ─────────────────────────────────────────
# Default (prod profile):  Ollama on host → http://host.docker.internal:11434
# GPU profile:             http://ollama-gpu:11434
# CPU profile:             http://ollama-cpu:11434
# Local (no Docker):       http://localhost:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_LLM_MODEL=llama3
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ── Chunking ────────────────────────────────────────────────────────
CHUNK_SIZE=1024
CHUNK_OVERLAP=128

# ── App ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
DEBUG=false

# ── UI ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_AGENTS_URL=http://localhost:8002
NEXT_PUBLIC_MCP_URL=http://localhost:8080
NEXT_PUBLIC_ENABLE_STREAMING=true
NEXT_PUBLIC_ENABLE_GRAPH_VIEW=true

# ── MCP Server ──────────────────────────────────────────────────────
KG_API_URL=http://api:8000
MCP_TRANSPORT=sse
MCP_HOST=0.0.0.0
MCP_PORT=8080

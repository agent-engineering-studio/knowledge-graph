# knowledge-graph-agents environment configuration
# Microsoft Agent Framework — powered by agent-framework (public preview)
# Install: pip install --pre "agent-framework[openai]"
# Copy this file to .env and adjust values for your environment

# URL of the knowledge-graph-api service
KG_API_URL=http://localhost:8000

# HTTP timeout in seconds for API calls
KG_API_TIMEOUT=60

# Ollama — used via OpenAI-compatible API (agent_framework.openai.OpenAIChatClient)
# The agent framework connects to: OLLAMA_BASE_URL/v1
# OPENAI_CHAT_MODEL_ID is set programmatically from OLLAMA_LLM_MODEL (see agents/client.py)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=qwen2.5:7b
# Set explicitly if you want to override the model for agent-framework directly:
# OPENAI_CHAT_MODEL_ID=qwen2.5:7b

# Agent API port (uvicorn)
# Start with: uvicorn api.agent_api:app --port 8001
AGENT_API_PORT=8001

# Redis — same instance used by knowledge-graph-api (vector store)
# Prefix "agent:" keeps agent keys separate from KG vector/graph data
REDIS_URL=redis://localhost:6379
